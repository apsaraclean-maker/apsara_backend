# ─────────────────────────────────────────────────────────────
# Apsara Clean — Notion Sync Config
# Copy this file to .env.notion and fill in your values.
# Get your token at: https://notion.so/my-integrations
# ─────────────────────────────────────────────────────────────

NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Page IDs — copy from the URL of each Notion page
# e.g. notion.so/My-Page-Title-1a2b3c4d5e6f → ID is 1a2b3c4d5e6f

NOTION_API_PAGE_ID=
NOTION_DB_PAGE_ID=
NOTION_FEATURES_PAGE_ID=
NOTION_ENHANCEMENTS_PAGE_ID=
NOTION_TECHSTACK_PAGE_ID=
NOTION_ARCHITECTURE_PAGE_ID=
